# Normalize line endings: store LF in git, check out LF everywhere.
# Kills CRLF/LF churn when files are edited on Windows.
* text=auto eol=lf

# Binary assets — never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.pdf binary
